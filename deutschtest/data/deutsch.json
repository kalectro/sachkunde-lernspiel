            {"id": "de_v_6_02", "type": "mc", "diff": 1, "q": "Die Grundform endet fast immer auf…", "options": ["-en", "-e", "-st", "-t"], "correct": 0, "explanation": "Richtig! Die Grundform endet meistens auf -en: lesen, spielen, lachen."},
            {"id": "de_v_6_03", "type": "type", "diff": 1, "q": "Wie heißt die Grundform von «du malst»?", "accept": ["malen"], "explanation": "malen — die Grundform endet auf -en! 🎨"},
            {"id": "de_v_6_04", "type": "type", "diff": 1, "q": "Wie heißt die Grundform von «ich singe»?", "accept": ["singen"], "explanation": "singen! 🎵"},
            {"id": "de_v_6_05", "type": "type", "diff": 1, "q": "Wie heißt die Grundform von «wir lesen»?", "accept": ["lesen"], "explanation": "lesen! 📖"},
            {"id": "de_v_6_06", "type": "type", "diff": 2, "q": "Wie heißt die Grundform von «er springt»?", "accept": ["springen"], "explanation": "springen! 🦘"},
            {"id": "de_v_6_07", "type": "mc", "diff": 2, "q": "Welches Verb steht in der Grundform?", "options": ["lachen", "lache", "lachst", "lacht"], "correct": 0, "explanation": "«lachen» ist die Grundform. Die anderen sind Personalformen: ich lache, du lachst, er lacht."},
            {"id": "de_v_6_08", "type": "mc", "diff": 2, "q": "Welches Verb steht NICHT in der Grundform?", "options": ["fragst", "fragen", "essen", "kochen"], "correct": 0, "explanation": "«fragst» ist eine Personalform (du fragst). Die Grundform heißt «fragen»."},
            {"id": "de_v_6_09", "type": "mc", "diff": 2, "q": "Auf welche Endung endet «feiern»?", "options": ["-ern", "-en", "-eln", "-t"], "correct": 0, "explanation": "feiern endet auf -ern! 🎉 Auch: wandern, baggern, ärgern."},
            {"id": "de_v_6_10", "type": "mc", "diff": 2, "q": "Auf welche Endung endet «basteln»?", "options": ["-eln", "-en", "-ern", "-st"], "correct": 0, "explanation": "basteln endet auf -eln! ✂️ Auch: bügeln, lächeln, bummeln."},
            {"id": "de_v_6_11", "type": "mc", "diff": 1, "q": "Auf welche Endung endet «sagen»?", "options": ["-en", "-ern", "-eln", "-gen"], "correct": 0, "explanation": "sagen endet auf -en — wie die meisten Verben."},
