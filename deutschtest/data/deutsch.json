            {"id": "de_v_1_b1", "type": "type", "diff": 3, "bonus": true, "q": "Welcher Artikel passt zu «Kind»?", "accept": ["das", "das kind"], "explanation": "Bonus! das Kind — sächlich, auch wenn es ein Junge oder Mädchen ist!"}
          ]
        },
