            {"id": "de_v_1_02", "type": "mc", "diff": 1, "q": "Welcher Artikel passt zu «Katze»?", "options": ["die", "der", "das"], "correct": 0, "explanation": "die Katze — weiblich! 🐱"},
            {"id": "de_v_1_03", "type": "mc", "diff": 1, "q": "Welcher Artikel passt zu «Auto»?", "options": ["das", "der", "die"], "correct": 0, "explanation": "das Auto — sächlich! 🚗"},
            {"id": "de_v_1_04", "type": "mc", "diff": 1, "q": "Welcher Artikel passt zu «Traktor»?", "options": ["der", "die", "das"], "correct": 0, "explanation": "der Traktor — männlich! 🚜"},
            {"id": "de_v_1_05", "type": "mc", "diff": 1, "q": "Welcher Artikel passt zu «Bahn»?", "options": ["die", "der", "das"], "correct": 0, "explanation": "die Bahn — weiblich! 🚆"},
            {"id": "de_v_1_06", "type": "mc", "diff": 1, "q": "Welcher Artikel passt zu «Flugzeug»?", "options": ["das", "der", "die"], "correct": 0, "explanation": "das Flugzeug — sächlich! ✈️"},
            {"id": "de_v_1_07", "type": "mc", "diff": 1, "q": "Welches Wort ist ein NOMEN?", "options": ["Baum", "laufen", "schön", "schnell"], "correct": 0, "explanation": "Nomen sind Wörter für Menschen, Tiere, Pflanzen oder Dinge. «Baum» ist ein Ding! 🌳"},
            {"id": "de_v_1_08", "type": "mc", "diff": 2, "q": "Welches Wort ist KEIN Nomen?", "options": ["singen", "Lied", "Kind", "Mutter"], "correct": 0, "explanation": "«Singen» ist ein Verb (Tunwort). Nomen sind z.B. Lied, Kind, Mutter."},
            {"id": "de_v_1_09", "type": "tf", "diff": 1, "q": "Nomen schreibt man groß.", "correct": true, "explanation": "Richtig! Nomen beginnen immer mit einem großen Buchstaben. 📝"},
            {"id": "de_v_1_10", "type": "tf", "diff": 1, "q": "Verben schreibt man groß.", "correct": false, "explanation": "Falsch! Verben (Tunwörter) schreibt man klein."},
            {"id": "de_v_1_11", "type": "tf", "diff": 2, "q": "Vor einem Nomen kann man immer «der», «die» oder «das» setzen.", "correct": true, "explanation": "Richtig! Jedes Nomen hat einen Artikel: der, die oder das."},
            {"id": "de_v_1_12", "type": "type", "diff": 2, "q": "Schreibe den Artikel zu «Pferd».", "accept": ["das", "das pferd"], "explanation": "das Pferd — sächlich! 🐴"},
            {"id": "de_v_1_13", "type": "type", "diff": 2, "q": "Schreibe den Artikel zu «Bagger».", "accept": ["der", "der bagger"], "explanation": "der Bagger — männlich!"},
            {"id": "de_v_1_14", "type": "type", "diff": 2, "q": "Schreibe den Artikel zu «Kutsche».", "accept": ["die", "die kutsche"], "explanation": "die Kutsche — weiblich!"},
            {"id": "de_v_1_15", "type": "mc", "diff": 2, "q": "Welches Wort ist ein Nomen?", "options": ["Futternapf", "fressen", "hungrig", "schnell"], "correct": 0, "explanation": "«Futternapf» ist ein Ding — ein Nomen! 🥣"},
            {"id": "de_v_1_16", "type": "type", "diff": 3, "q": "Wie heißt der Oberbegriff für Wörter wie Hund, Katze, Tisch, Karl?", "accept": ["nomen", "namenwort", "namenwörter", "namenwoerter"], "explanation": "Das sind alles NOMEN (auch Namenwörter genannt)!", "hint": "Beginnt mit N und hat 5 Buchstaben."},
