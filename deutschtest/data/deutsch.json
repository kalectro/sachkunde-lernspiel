            {"id": "de_v_2_02", "type": "mc", "diff": 1, "q": "Welches Wort ist KEIN Verb?", "options": ["Tisch", "essen", "trinken", "schlafen"], "correct": 0, "explanation": "«Tisch» ist ein Nomen. Verben sind essen, trinken, schlafen."},
            {"id": "de_v_2_03", "type": "mc", "diff": 1, "q": "Was passt zum Bild eines schlafenden Kindes?", "options": ["schlafen", "essen", "malen", "lesen"], "correct": 0, "explanation": "Das Kind schläft — das Verb ist «schlafen»! 😴"},
            {"id": "de_v_2_04", "type": "mc", "diff": 1, "q": "Was passt: Das Kind hält ein Buch und…", "options": ["liest", "schneidet", "kocht", "tanzt"], "correct": 0, "explanation": "Mit einem Buch: lesen! 📖"},
            {"id": "de_v_2_05", "type": "mc", "diff": 1, "q": "Welches Verb passt: «Die Katze ___ Milch.»", "options": ["trinkt", "backt", "schwimmt", "schreibt"], "correct": 0, "explanation": "Die Katze trinkt Milch! 🥛"},
            {"id": "de_v_2_06", "type": "mc", "diff": 1, "q": "Welches Verb passt: «Die Ente ___ vor Angst.»", "options": ["piepst", "kräht", "quakt", "bellt"], "correct": 0, "explanation": "Die Ente piepst vor Angst! 🦆"},
            {"id": "de_v_2_07", "type": "mc", "diff": 2, "q": "Welches Verb passt: «Der Hahn ___ kikeriki.»", "options": ["kräht", "bellt", "miaut", "quakt"], "correct": 0, "explanation": "Der Hahn kräht kikeriki! 🐓"},
            {"id": "de_v_2_08", "type": "mc", "diff": 2, "q": "Welches Verb passt: «Der Frosch ___ quak.»", "options": ["quakt", "bellt", "piept", "kräht"], "correct": 0, "explanation": "Der Frosch quakt! 🐸"},
            {"id": "de_v_2_09", "type": "tf", "diff": 1, "q": "Verben schreibt man klein.", "correct": true, "explanation": "Richtig! Verben werden kleingeschrieben."},
            {"id": "de_v_2_10", "type": "tf", "diff": 2, "q": "Verben sagen, was jemand tut.", "correct": true, "explanation": "Richtig! Verben beschreiben, was Menschen, Tiere oder Dinge tun."},
            {"id": "de_v_2_11", "type": "tf", "diff": 2, "q": "Ein Satz kann ohne Verb sein.", "correct": false, "explanation": "Falsch! Jeder Satz braucht ein Verb."},
            {"id": "de_v_2_12", "type": "type", "diff": 2, "q": "Wie heißt das Tunwort für «mit dem Mund Essen zu sich nehmen»?", "accept": ["essen"], "explanation": "Essen! 🍎"},
            {"id": "de_v_2_13", "type": "type", "diff": 2, "q": "Wie heißt das Tunwort für «mit einem Stift ein Bild machen»?", "accept": ["malen"], "explanation": "Malen! 🎨"},
            {"id": "de_v_2_14", "type": "type", "diff": 2, "q": "Wie heißt das Tunwort für «ein Buch betrachten und die Wörter verstehen»?", "accept": ["lesen"], "explanation": "Lesen! 📖"},
            {"id": "de_v_2_15", "type": "type", "diff": 3, "q": "Suche das Verb: «Der Vogel zwitschert hoch im Baum.»", "accept": ["zwitschert", "zwitschern"], "explanation": "Das Verb ist «zwitschert»! 🐦"},
            {"id": "de_v_2_16", "type": "type", "diff": 3, "q": "Suche das Verb: «Die Maus beißt den Brief an.»", "accept": ["beißt", "beisst", "beissen", "beißen"], "explanation": "Das Verb ist «beißt»! 🐭"},
            {"id": "de_v_2_17", "type": "sort", "diff": 3, "q": "Ordne die Verben nach dem Alphabet!", "items": ["essen", "lesen", "malen", "schlafen"], "explanation": "Alphabetisch: essen, lesen, malen, schlafen!"},
            {"id": "de_v_2_18", "type": "mc", "diff": 3, "q": "Welcher Satz enthält ZWEI Verben?", "options": ["Ich möchte schlafen.", "Das Pferd läuft.", "Die Katze schläft.", "Der Hund bellt."], "correct": 0, "explanation": "«möchte» und «schlafen» — beides Verben!"},
            {"id": "de_v_2_b1", "type": "type", "diff": 3, "bonus": true, "q": "Wie heißt der Oberbegriff für Wörter wie laufen, essen, malen, spielen?", "accept": ["verben", "verb", "tunwörter", "tunwoerter", "tunwort"], "explanation": "Verben oder Tunwörter! 🏃"}
          ]
